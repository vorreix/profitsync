# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─────────────────────────────────────────────────────────────
# Clerk (authentication)
#   Get these from https://dashboard.clerk.com → your app → API Keys.
#   VITE_* is exposed to the browser; CLERK_SECRET_KEY must stay server-only.
# ─────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ─────────────────────────────────────────────────────────────
# Platform admin (bootstrap)
#   The user(s) whose email matches ROOT_ADMIN_EMAILS are always platform admins
#   (no DB row needed) — this is how you get the first admin in production.
#   Comma-separated for multiple. They manage all other admins from /admin/admins.
# ─────────────────────────────────────────────────────────────
ROOT_ADMIN_EMAILS=you@example.com

# ─────────────────────────────────────────────────────────────
# Transactional email (Resend) — used for organization invitations.
#   RESEND_API_KEY → https://resend.com → API Keys.
#   EMAIL_FROM     → a verified sender on your domain, e.g.
#                    "ProfitSync <noreply@profitsync.net>".
#   OPTIONAL: if RESEND_API_KEY is blank, invitations still work — the inviter
#   just shares the generated link manually (no email is sent).
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ProfitSync <noreply@profitsync.net>

# ─────────────────────────────────────────────────────────────
# Neon Postgres (Drizzle ORM)
#   Get from https://console.neon.tech → your project → Connection string (Pooler).
#   Must include ?sslmode=require — `vercel dev` and serverless functions both use it.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require # placeholder, secret-scan:ignore

# ─────────────────────────────────────────────────────────────
# Dodo Payments (Merchant of Record — subscriptions + webhooks)
#   API key      → Dashboard → Developer → API Keys (use Test mode while developing).
#   Webhook secret → Dashboard → Developer → Webhooks; point the endpoint at
#     https://<your-deployment>/api/billing/webhook  (starts with whsec_)
#   Product IDs  → Dashboard → Products (create recurring products per plan/cycle).
#   ENVIRONMENT  → "test_mode" or "live_mode".
#   If DODO_PAYMENTS_API_KEY is blank, /api/billing/create-subscription falls into
#   stub mode (marks the org premium locally without calling Dodo) for QA.
#
#   NOTE: The source of truth for plan → product mapping is the `plans` table
#   (configurable in the admin panel: /admin/plans). These env vars are only a
#   fallback used when a plan row has no product id set.
# ─────────────────────────────────────────────────────────────
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_SECRET=
# Personal / Business plan products (Monthly + Yearly).
DODO_PRODUCT_PERSONAL_MONTHLY=
DODO_PRODUCT_PERSONAL_YEARLY=
DODO_PRODUCT_BUSINESS_MONTHLY=
DODO_PRODUCT_BUSINESS_YEARLY=
# Legacy single-tier product (kept for back-compat).
DODO_PRODUCT_PREMIUM_MONTHLY=
DODO_PRODUCT_PREMIUM_YEARLY=

# ─────────────────────────────────────────────────────────────
# Web Push (VAPID) — notification system, OPTIONAL.
#   Powers browser/PWA push notifications. The in-app notification system (bell,
#   history, per-user/org/client preferences) works WITHOUT these — push is just
#   an extra delivery channel. If blank, push is silently disabled and the
#   "Enable push notifications" toggle is hidden.
#
#   NO Firebase/FCM project, GCM key, or third-party account is needed: this uses
#   the standard Web Push Protocol with VAPID. Generate your own keypair with:
#       npx web-push generate-vapid-keys
#   Then map: Public Key  → VAPID_PUBLIC_KEY *and* VITE_VAPID_PUBLIC_KEY
#             Private Key → VAPID_PRIVATE_KEY (server-only, keep secret)
#   VAPID_SUBJECT is a contact URL the push services can reach you at
#   (mailto:you@yourdomain or https://yourdomain). Generate FRESH keys per
#   environment; never reuse a private key or commit it.
#
#   ⚠ VITE_VAPID_PUBLIC_KEY is read at BUILD time (baked into the browser bundle),
#     so it must be present when the production build runs.
# ─────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com
VITE_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────
# Background worker service (worker/ — deployed separately) — OPTIONAL.
#   Lets /admin → Worker show queue status and lets the app enqueue jobs /
#   register schedules. WORKER_API_TOKEN must match the worker's own value.
#   Server-side only — the token is never sent to the browser (admin calls go
#   through /api/admin/worker). If unset, the /admin Worker panel shows
#   "not configured". See docs/worker/ARCHITECTURE_DECISION.md.
# ─────────────────────────────────────────────────────────────
WORKER_BASE_URL=
WORKER_API_TOKEN=

# ─────────────────────────────────────────────────────────────
# Notification scheduler (timed reminders + scheduled/recurring broadcasts).
#   PROFITSYNC_SERVICE_TOKEN authenticates server-to-server calls INTO the app:
#   the worker (or any pinger) POSTs /api/cron/notifications with this as a bearer
#   token to deliver due reminders + broadcasts. It is the SAME secret set on the
#   worker (worker→app). Generate with: openssl rand -hex 32. Never sent to the
#   browser. If unset, /api/cron/notifications returns 503 and timed delivery is
#   simply off (in-app + immediate broadcasts still work).
# ─────────────────────────────────────────────────────────────
PROFITSYNC_SERVICE_TOKEN=

# ─────────────────────────────────────────────────────────────
# S3 / object storage (quotation PDFs) — OPTIONAL.
#   These are the app's READ credentials: the app mints a fresh short-lived
#   (~1h) presigned GET URL every time someone views/downloads a quotation PDF,
#   so a shared link expires on its own. The Go WORKER holds the matching WRITE
#   credentials (worker/deploy/.env → same S3_* names) and uploads the bytes.
#   One Hetzner Object Storage key can serve both sides, or you can split
#   read-only vs read-write keys.
#
#   ⚠ SERVER-ONLY. These are secrets — they must NEVER be exposed to the browser
#     (no VITE_ prefix). The client only ever receives a *presigned URL* (which
#     carries a signature, not the key). Keep the bucket PRIVATE: there is no
#     public URL for quotation PDFs — the presigned URL from the authed,
#     org-scoped route (GET /api/quotations/:id/pdf) is the only path to the bytes.
#
#   Works with Hetzner Object Storage, MinIO, AWS S3, or any S3-compatible store.
#   Example (Hetzner, Falkenstein): S3_ENDPOINT=fsn1.your-objectstorage.com
#   If S3_ENDPOINT/S3_BUCKET/S3_ACCESS_KEY/S3_SECRET_KEY are blank, the PDF modal
#   shows "PDF generation is not available" (503) and nothing breaks.
#
#   S3_USE_SSL         → "false" for plain HTTP (default true). Leave true in prod.
#   S3_FORCE_PATH_STYLE→ path-style host/bucket/key (default true; the correct
#                        setting for Hetzner + MinIO custom endpoints). Set "false"
#                        only for virtual-hosted-style (bucket.host) providers.
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# AI quick add (NL text + receipt photo + voice → prefilled transaction) — OPTIONAL.
#   The ✨ trigger in the Add-Transaction modal is hidden entirely until a
#   provider key is set, so leaving all of this blank changes nothing.
#
#   AI_PROVIDER      → which provider to use: "gemini" | "anthropic" | "openai".
#                      If blank, the first configured key wins in the order
#                      anthropic → gemini → openai — so set it explicitly.
#   AI_PARSE_MODEL   → optional model override. Per-provider defaults:
#                      gemini    → gemini-3.1-flash-lite (recommended; cheapest current-gen with voice —
#                                  2.5-generation models are CLOSED to new Google projects: 404 "no longer available to new users")
#                      anthropic → claude-haiku-4-5
#                      openai    → gpt-5.4-mini
#
#   ⚠ VOICE input ("I spent 50 euros from account A", any app language) works
#     ONLY with gemini — Anthropic and OpenAI mini-tier models don't accept
#     audio, so with those providers the mic button auto-hides (text + receipt
#     still work). Voice limits: 30s/recording free, 60s premium; all AI usage
#     shares plans.limits.aiParsesPerMonth (free 30/mo, premium 500/mo).
#
#   Keys (all SERVER-ONLY — never VITE_-prefixed):
#     GEMINI_API_KEY    → https://aistudio.google.com → Get API key.
#                         Free tier: 10 req/min, 250 req/day — fine for dev.
#     ANTHROPIC_API_KEY → https://console.anthropic.com → API Keys.
#     OPENAI_API_KEY    → https://platform.openai.com → API Keys.
#   Only the key for the selected provider is needed.
# ─────────────────────────────────────────────────────────────
# gemini, openai, anthropic
AI_PROVIDER=gemini
AI_PARSE_MODEL=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
#   Monthly AI CREDIT pool (shared by every AI feature) + per-action weights.
#   Quick add (text/receipt/voice fill) costs AI_CREDITS_QUICKADD credits and
#   the voice assistant costs AI_CREDITS_ASSISTANT. A per-plan value in the
#   admin panel (/admin/plans → limits.aiParsesPerMonth) still overrides the
#   pool size. All optional — defaults shown.
AI_MONTHLY_CREDITS_FREE=30
AI_MONTHLY_CREDITS_PREMIUM=500
AI_CREDITS_QUICKADD=1
AI_CREDITS_ASSISTANT=2
