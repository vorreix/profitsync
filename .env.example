# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─────────────────────────────────────────────────────────────
# Clerk (authentication)
#   Get these from https://dashboard.clerk.com → your app → API Keys.
#   VITE_* is exposed to the browser; CLERK_SECRET_KEY must stay server-only.
# ─────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ─────────────────────────────────────────────────────────────
# Neon Postgres (Drizzle ORM)
#   Get from https://console.neon.tech → your project → Connection string (Pooler).
#   Must include ?sslmode=require — `vercel dev` and serverless functions both use it.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# ─────────────────────────────────────────────────────────────
# Razorpay (subscriptions + webhooks)
#   Dashboard → Settings → API Keys (use Test Mode while developing).
#   Webhook secret → Dashboard → Settings → Webhooks; point it at
#     https://<your-deployment>/api/billing/webhook
#   If all three are blank, /api/billing/create-subscription falls into
#   stub mode (marks the org premium locally without calling Razorpay),
#   which is handy for QA without live keys.
# ─────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
