# ProfitSync pre-commit gate — mirrors `make pr` and the CI workflow:
#   lint -> type check -> tests
#
# This hook is installed automatically when you run `npm install`
# (via the "prepare": "husky" script in package.json). No manual setup needed.

# Force dependencies to be installed before committing.
if [ ! -d node_modules ]; then
  echo "✗ node_modules is missing — run \`npm install\` before committing."
  exit 1
fi

echo "→ secret scan (staged diff)..."
node scripts/secret-scan.mjs || { echo "✗ secret scan failed — remove the credential (rotate it if it was real) or mark a safe example with secret-scan:ignore"; exit 1; }

echo "→ ESM import extensions (api/ function graph)..."
node scripts/check-esm-extensions.mjs || { echo "✗ ESM extension check failed — add the .js extension (extensionless relative imports crash every /api route in production)"; exit 1; }

echo "→ functions boot under Node ESM (prod parity)..."
node scripts/boot-functions.mjs || { echo "✗ a serverless function fails to load exactly as it would in production (FUNCTION_INVOCATION_FAILED) — fix the import/module-scope error above"; exit 1; }

echo "→ i18n parity (all locales must match en.json)..."
npm run i18n:check || { echo "✗ i18n parity check failed — add the missing translations to every locale in src/lib/i18n/locales/"; exit 1; }

echo "→ lint..."
npm run lint || { echo "✗ lint failed"; exit 1; }

echo "→ type check..."
npm run typecheck || { echo "✗ type check failed"; exit 1; }

echo "→ tests..."
npm run test:ci || { echo "✗ tests failed"; exit 1; }

echo "✓ all checks passed"
