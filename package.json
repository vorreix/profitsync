{
  "name": "shadcn-ui-template",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:android": "tsc -b && vite build --mode android",
    "build:android:local": "tsc -b && vite build --mode android-local",
    "vercel-build": "node scripts/db-migrate.mjs && npm run build",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p api/tsconfig.json",
    "preview": "vite preview",
    "pwa:icons": "pwa-assets-generator -c pwa/pwa-assets.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:push": "drizzle-kit push",
    "seed-blog": "tsx scripts/seed-blog.ts",
    "i18n:check": "node scripts/check-i18n.mjs",
    "make-admin": "node scripts/make-admin.mjs",
    "lint": "eslint .",
    "test": "vitest",
    "test:ci": "vitest run",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "cap:sync:android": "npm run build:android && cap sync android",
    "cap:open:android": "npm run cap:sync:android && cap open android",
    "cap:build:android": "npm run cap:sync:android && node scripts/android-gradle.mjs assembleDebug",
    "cap:build:android:clean": "npm run cap:sync:android && powershell -ExecutionPolicy Bypass -File scripts/clean-android-build.ps1 && cd android && gradlew.bat assembleDebug",
    "cap:sync:android:local": "npm run build:android:local && cap sync android",
    "cap:build:android:local": "npm run cap:sync:android:local && node scripts/android-gradle.mjs assembleDebug"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@clerk/clerk-react": "^5.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@formkit/auto-animate": "^0.9.0",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.6.0",
    "marked": "^18.0.5",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^4.7.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@clerk/backend": "^1.0.0",
    "@clerk/testing": "^2.0.35",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^3.2.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
