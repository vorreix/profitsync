# Copy to .env (gitignored) and fill in. Used by docker-compose.

# ── Worker control API ───────────────────────────────────────────────────────
WORKER_PORT=8080
# Host interface the worker's port binds to. Default 127.0.0.1 = NOT reachable from
# the internet (the host nginx proxies it on localhost). Only set this to 0.0.0.0 if
# you must expose the worker directly without a TLS proxy — and then firewall the port.
WORKER_BIND=127.0.0.1
# Resolvers used INSIDE the containers (default 1.1.1.1 / 8.8.8.8). Override only if
# your network blocks public DNS — e.g. WORKER_DNS1=<internal resolver>. (Needed
# because a systemd-resolved host leaks the 127.0.0.53 stub into containers, which
# then can't resolve anything → the app callback to PROFITSYNC_BASE_URL fails.)
#WORKER_DNS1=1.1.1.1
#WORKER_DNS2=8.8.8.8
# Bearer token ProfitSync must send to enqueue jobs / upsert schedules.
# Generate: openssl rand -hex 32
WORKER_API_TOKEN=

# ── TLS reverse proxy (OPTIONAL — only used by the `proxy` compose profile) ───
# When you run `docker compose --profile proxy up -d` (or `make -C worker up-proxy`)
# a bundled Caddy service terminates HTTPS for WORKER_DOMAIN and forwards to the
# worker. Point WORKER_DOMAIN's DNS at this host + open ports 80/443 first. Then set
# the app's WORKER_BASE_URL = https://<WORKER_DOMAIN>.
WORKER_DOMAIN=worker.profitsync.net

# ── Worker's own Postgres (job queue) ────────────────────────────────────────
# Password for the bundled postgres service. DATABASE_URL is built from it in
# docker-compose.yml — do not set DATABASE_URL here.
POSTGRES_PASSWORD=

# ── Engine tuning (optional) ─────────────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL=2s
WORKER_JOB_TIMEOUT=5m
WORKER_MAX_ATTEMPTS=5
# A job stuck in 'running' this long (worker crashed mid-job) is reaped +
# requeued. Keep comfortably ABOVE WORKER_JOB_TIMEOUT.
WORKER_VISIBILITY_TIMEOUT=10m
# Max wait for in-flight jobs to finish on shutdown (SIGTERM) before exit.
WORKER_SHUTDOWN_GRACE=30s

# ── Logging (optional) ───────────────────────────────────────────────────────
# Logs always go to stdout (`docker compose logs`). docker-compose also sets
# WORKER_LOG_DIR=/app/logs (a persistent volume) so logs are ALSO written to a
# size-rotated file you can tail: `docker compose exec worker tail -f /app/logs/worker.log`.
WORKER_LOG_LEVEL=info        # debug | info | warn | error  (use debug to see ticks/claims)
WORKER_LOG_MAX_SIZE_MB=50    # rotate after a file reaches this size
WORKER_LOG_MAX_BACKUPS=10    # how many rotated files to keep
WORKER_LOG_MAX_AGE_DAYS=30   # delete rotated files older than this
WORKER_LOG_COMPRESS=true     # gzip rotated files

# ── ProfitSync app callback (trigger-style jobs) ─────────────────────────────
# The app's base URL + a shared service token the app verifies on its internal
# endpoints (e.g. /api/internal/cron/*). Generate the token: openssl rand -hex 32
PROFITSYNC_BASE_URL=https://profitsync.net
PROFITSYNC_SERVICE_TOKEN=

# ── S3 / S3-compatible object storage (PDF/CSV results) — optional ───────────
# Works with Hetzner Object Storage, MinIO, AWS S3, etc.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true
# Optional public base URL (CDN/bucket) used to build returned file URLs; if
# unset, the worker returns time-limited presigned URLs instead.
S3_PUBLIC_URL=
