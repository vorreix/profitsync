# Host-nginx reverse proxy for the ProfitSync worker.
#
# Use this when the server ALREADY runs nginx on ports 80/443 (other sites), so the
# bundled Caddy `proxy` profile can't bind those ports. The worker stays private on
# 127.0.0.1:8656 (WORKER_BIND default) and your existing host nginx fronts it.
#
# Install:
#   sudo cp nginx-worker.conf.example /etc/nginx/sites-available/worker.profitsync.net
#   sudo ln -s /etc/nginx/sites-available/worker.profitsync.net /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d worker.profitsync.net   # adds the TLS (443) block + HTTP->HTTPS redirect
#
# Prereqs: DNS A/AAAA for worker.profitsync.net -> this host; the worker running via
#   `make -C worker up`  (NOT up-proxy — nginx is the proxy here, not Caddy).

server {
    listen 80;
    listen [::]:80;
    server_name worker.profitsync.net;

    # API only; raise if you ever enqueue large job payloads through it.
    client_max_body_size 5m;

    location / {
        proxy_pass         http://127.0.0.1:8656;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
