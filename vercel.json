{
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "{api/_ssr/index-template.html,src/landing/i18n/locales/en.json}"
    }
  },
  "redirects": [
    {
      "source": "/:path((?!sw\\.js$|api/).*)",
      "has": [{ "type": "host", "value": "www.profitsync.net" }],
      "destination": "https://profitsync.net/:path",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.profitsync.net" }],
      "destination": "https://profitsync.net/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?__apipath=$1"
    },
    {
      "source": "/sw.js",
      "destination": "/kill-sw.js"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/ssr?__ssrpath=robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/ssr?__ssrpath=sitemap.xml"
    },
    {
      "source": "/llms.txt",
      "destination": "/api/ssr?__ssrpath=llms.txt"
    },
    {
      "source": "/",
      "destination": "/api/ssr?__ssrpath="
    },
    {
      "source": "/blog",
      "destination": "/api/ssr?__ssrpath=blog"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/ssr?__ssrpath=blog/:slug"
    },
    {
      "source": "/privacy-policy",
      "destination": "/api/ssr?__ssrpath=privacy-policy"
    },
    {
      "source": "/terms-of-service",
      "destination": "/api/ssr?__ssrpath=terms-of-service"
    },
    {
      "source": "/refund-policy",
      "destination": "/api/ssr?__ssrpath=refund-policy"
    },
    {
      "source": "/((?!api|@)[^.]*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app-sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/kill-sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
      ]
    }
  ]
}
